<section class="lore-forge-step" data-step="magic">
  <h2>{{localize "LORE_FORGE.Kingdom.Steps.Magic"}}</h2>
  <p class="step-description">{{localize "LORE_FORGE.Kingdom.Magic.Desc"}}</p>

  <div class="lf-form">
    {{!-- Religion (migrated from Government) --}}
    <div class="form-group">
      <label>{{localize "LORE_FORGE.Kingdom.Magic.Religion"}}</label>
      <div class="inspiration-row">
        <textarea name="religion" rows="2"
                  placeholder="{{localize 'LORE_FORGE.Kingdom.Magic.ReligionPlaceholder'}}">{{data.religion}}</textarea>
        <button type="button" class="inspire-btn" data-action="inspire" data-field="religions">
          <i class="fas fa-dice-d20"></i>
        </button>
      </div>
    </div>

    {{!-- Pantheon --}}
    <div class="form-group">
      <label>{{localize "LORE_FORGE.Kingdom.Magic.Pantheon"}}</label>
      <div class="inspiration-row">
        <textarea name="pantheon" rows="2"
                  placeholder="{{localize 'LORE_FORGE.Kingdom.Magic.PantheonPlaceholder'}}">{{data.pantheon}}</textarea>
        <button type="button" class="inspire-btn" data-action="inspire" data-field="pantheons">
          <i class="fas fa-dice-d20"></i>
        </button>
      </div>
    </div>

    {{!-- Religious Orders --}}
    <div class="form-group">
      <label>{{localize "LORE_FORGE.Kingdom.Magic.ReligiousOrders"}}</label>
      <div class="inspiration-row">
        <textarea name="religiousOrders" rows="2"
                  placeholder="{{localize 'LORE_FORGE.Kingdom.Magic.ReligiousOrdersPlaceholder'}}">{{data.religiousOrders}}</textarea>
        <button type="button" class="inspire-btn" data-action="inspire" data-field="religiousOrders">
          <i class="fas fa-dice-d20"></i>
        </button>
      </div>
    </div>

    {{!-- Magical Institutions --}}
    <div class="form-group">
      <label>{{localize "LORE_FORGE.Kingdom.Magic.MagicalInstitutions"}}</label>
      <div class="inspiration-row">
        <textarea name="magicalInstitutions" rows="2"
                  placeholder="{{localize 'LORE_FORGE.Kingdom.Magic.MagicalInstitutionsPlaceholder'}}">{{data.magicalInstitutions}}</textarea>
        <button type="button" class="inspire-btn" data-action="inspire" data-field="magicalInstitutions">
          <i class="fas fa-dice-d20"></i>
        </button>
      </div>
    </div>

    {{!-- Arcane Laws --}}
    <div class="form-group">
      <label>{{localize "LORE_FORGE.Kingdom.Magic.ArcaneLaws"}}</label>
      <div class="inspiration-row">
        <textarea name="arcaneLaws" rows="2"
                  placeholder="{{localize 'LORE_FORGE.Kingdom.Magic.ArcaneLawsPlaceholder'}}">{{data.arcaneLaws}}</textarea>
        <button type="button" class="inspire-btn" data-action="inspire" data-field="arcaneLaws">
          <i class="fas fa-dice-d20"></i>
        </button>
      </div>
    </div>
  </div>
</section>
