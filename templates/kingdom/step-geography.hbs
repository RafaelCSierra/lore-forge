<section class="lore-forge-step" data-step="geography">
  <h2>{{localize "LORE_FORGE.Kingdom.Steps.Geography"}}</h2>
  <p class="step-description">{{localize "LORE_FORGE.Kingdom.Geography.Desc"}}</p>

  <div class="lf-form">
    <div class="lf-form-row">
      {{!-- Terrain --}}
      <div class="form-group">
        <label>{{localize "LORE_FORGE.Kingdom.Geography.Terrain"}}</label>
        <select name="terrain">
          {{#each terrains}}
          <option value="{{this.value}}" {{#if (eq ../data.terrain this.value)}}selected{{/if}}>
            {{localize this.label}}
          </option>
          {{/each}}
        </select>
      </div>

      {{!-- Climate --}}
      <div class="form-group">
        <label>{{localize "LORE_FORGE.Kingdom.Geography.Climate"}}</label>
        <select name="climate">
          {{#each climates}}
          <option value="{{this.value}}" {{#if (eq ../data.climate this.value)}}selected{{/if}}>
            {{localize this.label}}
          </option>
          {{/each}}
        </select>
      </div>
    </div>

    {{!-- Landmarks --}}
    <div class="form-group">
      <label>{{localize "LORE_FORGE.Kingdom.Geography.Landmarks"}}</label>
      <div class="inspiration-row">
        <textarea name="landmarks" rows="3"
                  placeholder="{{localize 'LORE_FORGE.Kingdom.Geography.LandmarksPlaceholder'}}">{{data.landmarks}}</textarea>
        <button type="button" class="inspire-btn" data-action="inspire" data-field="landmarks">
          <i class="fas fa-dice-d20"></i>
        </button>
      </div>
    </div>

    {{!-- Resources --}}
    <div class="form-group">
      <label>{{localize "LORE_FORGE.Kingdom.Geography.Resources"}}</label>
      <div class="inspiration-row">
        <textarea name="resources" rows="3"
                  placeholder="{{localize 'LORE_FORGE.Kingdom.Geography.ResourcesPlaceholder'}}">{{data.resources}}</textarea>
        <button type="button" class="inspire-btn" data-action="inspire" data-field="resources">
          <i class="fas fa-dice-d20"></i>
        </button>
      </div>
    </div>
  </div>
</section>
