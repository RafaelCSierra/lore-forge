<section class="lore-forge-step" data-step="history">
  <h2>{{localize "LORE_FORGE.Kingdom.Steps.History"}}</h2>
  <p class="step-description">{{localize "LORE_FORGE.Kingdom.History.Desc"}}</p>

  <div class="lf-form">
    {{!-- Founding Story --}}
    <div class="form-group">
      <label>{{localize "LORE_FORGE.Kingdom.History.FoundingStory"}}</label>
      <div class="inspiration-row">
        <textarea name="foundingStory" rows="4"
                  placeholder="{{localize 'LORE_FORGE.Kingdom.History.FoundingStoryPlaceholder'}}">{{data.foundingStory}}</textarea>
        <button type="button" class="inspire-btn" data-action="inspire" data-field="foundingStories">
          <i class="fas fa-dice-d20"></i>
        </button>
      </div>
    </div>

    {{!-- Wealth Level --}}
    <div class="form-group">
      <label>{{localize "LORE_FORGE.Kingdom.Economy.WealthLevel"}}</label>
      <select name="wealthLevel">
        {{#each wealthLevels}}
        <option value="{{this.value}}" {{#if (eq ../data.wealthLevel this.value)}}selected{{/if}}>
          {{localize this.label}}
        </option>
        {{/each}}
      </select>
    </div>

    {{!-- Industries --}}
    <div class="form-group">
      <label>{{localize "LORE_FORGE.Kingdom.Economy.Industries"}}</label>
      <div class="inspiration-row">
        <textarea name="industries" rows="3"
                  placeholder="{{localize 'LORE_FORGE.Kingdom.Economy.IndustriesPlaceholder'}}">{{data.industries}}</textarea>
        <button type="button" class="inspire-btn" data-action="inspire" data-field="industries">
          <i class="fas fa-dice-d20"></i>
        </button>
      </div>
    </div>
  </div>
</section>
