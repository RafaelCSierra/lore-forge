<section class="lore-forge-step" data-step="review">
  <h2>{{localize "LORE_FORGE.Settlement.Steps.Review"}}</h2>
  <p class="step-description">{{localize "LORE_FORGE.Settlement.Review.Desc"}}</p>

  <div class="lf-review-preview">
    {{!-- Identity --}}
    <h3><i class="fas fa-city"></i> {{data.name}}</h3>

    {{#if regionName}}
    <div class="lf-field">
      <span class="lf-field-label">{{localize "LORE_FORGE.Common.Region"}}:</span>
      {{regionName}}
    </div>
    {{/if}}
    <div class="lf-field">
      <span class="lf-field-label">{{localize "LORE_FORGE.Settlement.Review.Size"}}:</span>
      {{settlementSizeLabel}}
    </div>
    {{#if data.population}}
    <div class="lf-field">
      <span class="lf-field-label">{{localize "LORE_FORGE.Settlement.Review.Population"}}:</span>
      {{data.population}}
    </div>
    {{/if}}
    {{#if data.leaderName}}
    <div class="lf-field">
      <span class="lf-field-label">{{localize "LORE_FORGE.Settlement.Review.Leader"}}:</span>
      {{data.leaderName}}{{#if data.leaderDesc}} — {{data.leaderDesc}}{{/if}}
    </div>
    {{/if}}
    {{#if data.founding}}
    <div class="lf-field">
      <span class="lf-field-label">{{localize "LORE_FORGE.Settlement.Review.Founding"}}:</span>
      {{data.founding}}
    </div>
    {{/if}}

    {{!-- Geography --}}
    {{#if hasGeography}}
    <h4><i class="fas fa-map"></i> {{localize "LORE_FORGE.Settlement.Review.Geography"}}</h4>
    {{#each districts}}
    <div class="lf-field">
      <span class="lf-field-label">{{this.name}}:</span>
      {{this.desc}}
    </div>
    {{/each}}
    {{#if data.landmarks}}
    <div class="lf-field">
      <span class="lf-field-label">{{localize "LORE_FORGE.Settlement.Review.Landmarks"}}:</span>
      {{data.landmarks}}
    </div>
    {{/if}}
    {{#if data.defenses}}
    <div class="lf-field">
      <span class="lf-field-label">{{localize "LORE_FORGE.Settlement.Review.Defenses"}}:</span>
      {{data.defenses}}
    </div>
    {{/if}}
    {{/if}}

    {{!-- Life & Trade --}}
    {{#if hasLife}}
    <h4><i class="fas fa-store"></i> {{localize "LORE_FORGE.Settlement.Review.Life"}}</h4>
    {{#if data.economy}}
    <div class="lf-field">
      <span class="lf-field-label">{{localize "LORE_FORGE.Settlement.Review.Economy"}}:</span>
      {{data.economy}}
    </div>
    {{/if}}
    {{#if data.customs}}
    <div class="lf-field">
      <span class="lf-field-label">{{localize "LORE_FORGE.Settlement.Review.Customs"}}:</span>
      {{data.customs}}
    </div>
    {{/if}}
    {{/if}}

    {{!-- Influence & Hooks --}}
    {{#if hasInfluence}}
    <h4><i class="fas fa-users"></i> {{localize "LORE_FORGE.Settlement.Review.Influence"}}</h4>
    {{#if data.organizations}}
    <div class="lf-field">
      <span class="lf-field-label">{{localize "LORE_FORGE.Settlement.Review.Organizations"}}:</span>
      {{data.organizations}}
    </div>
    {{/if}}
    {{#each npcs}}
    <div class="lf-field">
      <span class="lf-field-label">{{this.name}}:</span>
      {{this.role}}{{#if this.desc}} — {{this.desc}}{{/if}}
    </div>
    {{/each}}
    {{#if data.rumors}}
    <div class="lf-field">
      <span class="lf-field-label">{{localize "LORE_FORGE.Settlement.Review.Rumors"}}:</span>
      {{data.rumors}}
    </div>
    {{/if}}
    {{#if data.plotHooks}}
    <div class="lf-field">
      <span class="lf-field-label">{{localize "LORE_FORGE.Settlement.Review.PlotHooks"}}:</span>
      {{data.plotHooks}}
    </div>
    {{/if}}
    {{/if}}
  </div>
</section>
