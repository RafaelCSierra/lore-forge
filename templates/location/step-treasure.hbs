<section class="lore-forge-step" data-step="treasure">
  <h2>{{localize "LORE_FORGE.Location.Steps.Treasure"}}</h2>
  <p class="step-description">{{localize "LORE_FORGE.Location.Treasure.Desc"}}</p>

  <div class="lf-form">
    {{!-- Notable Items --}}
    <div class="form-group">
      <label>{{localize "LORE_FORGE.Location.Treasure.NotableItems"}}</label>
      <div class="inspiration-row">
        <textarea name="notableItems" rows="2"
                  placeholder="{{localize 'LORE_FORGE.Location.Treasure.NotableItemsPlaceholder'}}">{{data.notableItems}}</textarea>
        <button type="button" class="inspire-btn" data-action="inspire" data-field="notableItems">
          <i class="fas fa-dice-d20"></i>
        </button>
      </div>
    </div>

    {{!-- Hidden Treasure --}}
    <div class="form-group">
      <label>{{localize "LORE_FORGE.Location.Treasure.HiddenTreasure"}}</label>
      <div class="inspiration-row">
        <textarea name="hiddenTreasure" rows="2"
                  placeholder="{{localize 'LORE_FORGE.Location.Treasure.HiddenTreasurePlaceholder'}}">{{data.hiddenTreasure}}</textarea>
        <button type="button" class="inspire-btn" data-action="inspire" data-field="hiddenTreasures">
          <i class="fas fa-dice-d20"></i>
        </button>
      </div>
    </div>

    {{!-- Stock / Inventory --}}
    <div class="form-group">
      <label>{{localize "LORE_FORGE.Location.Treasure.Stock"}}</label>
      <div class="inspiration-row">
        <textarea name="stock" rows="2"
                  placeholder="{{localize 'LORE_FORGE.Location.Treasure.StockPlaceholder'}}">{{data.stock}}</textarea>
        <button type="button" class="inspire-btn" data-action="inspire" data-field="stocks">
          <i class="fas fa-dice-d20"></i>
        </button>
      </div>
    </div>
  </div>
</section>
