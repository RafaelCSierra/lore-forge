<section class="lore-forge-step" data-step="economy">
  <h2>{{localize "LORE_FORGE.Kingdom.Steps.Economy"}}</h2>
  <p class="step-description">{{localize "LORE_FORGE.Kingdom.Economy.Desc"}}</p>

  <div class="lf-form">
    {{!-- Currency --}}
    <div class="form-group">
      <label>{{localize "LORE_FORGE.Kingdom.Economy.Currency"}}</label>
      <div class="inspiration-row">
        <input type="text" name="currency" value="{{data.currency}}"
               placeholder="{{localize 'LORE_FORGE.Kingdom.Economy.CurrencyPlaceholder'}}">
        <button type="button" class="inspire-btn" data-action="inspire" data-field="currencies">
          <i class="fas fa-dice-d20"></i>
        </button>
      </div>
    </div>

    {{!-- Wealth Level --}}
    <div class="form-group">
      <label>{{localize "LORE_FORGE.Kingdom.Economy.WealthLevel"}}</label>
      <select name="wealthLevel">
        {{#each wealthLevels}}
        <option value="{{this.value}}" {{#if (eq ../data.wealthLevel this.value)}}selected{{/if}}>
          {{localize this.label}}
        </option>
        {{/each}}
      </select>
    </div>

    {{!-- Industries --}}
    <div class="form-group">
      <label>{{localize "LORE_FORGE.Kingdom.Economy.Industries"}}</label>
      <div class="inspiration-row">
        <textarea name="industries" rows="3"
                  placeholder="{{localize 'LORE_FORGE.Kingdom.Economy.IndustriesPlaceholder'}}">{{data.industries}}</textarea>
        <button type="button" class="inspire-btn" data-action="inspire" data-field="industries">
          <i class="fas fa-dice-d20"></i>
        </button>
      </div>
    </div>

    {{!-- Trade Routes --}}
    <div class="form-group">
      <label>{{localize "LORE_FORGE.Kingdom.Economy.TradeRoutes"}}</label>
      <div class="inspiration-row">
        <textarea name="tradeRoutes" rows="3"
                  placeholder="{{localize 'LORE_FORGE.Kingdom.Economy.TradeRoutesPlaceholder'}}">{{data.tradeRoutes}}</textarea>
        <button type="button" class="inspire-btn" data-action="inspire" data-field="tradeRoutes">
          <i class="fas fa-dice-d20"></i>
        </button>
      </div>
    </div>
  </div>
</section>
