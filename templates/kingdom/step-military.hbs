<section class="lore-forge-step" data-step="military">
  <h2>{{localize "LORE_FORGE.Kingdom.Steps.Military"}}</h2>
  <p class="step-description">{{localize "LORE_FORGE.Kingdom.Military.Desc"}}</p>

  <div class="lf-form">
    {{!-- Military Forces --}}
    <div class="form-group">
      <label>{{localize "LORE_FORGE.Kingdom.Military.Forces"}}</label>
      <div class="inspiration-row">
        <textarea name="militaryForces" rows="3"
                  placeholder="{{localize 'LORE_FORGE.Kingdom.Military.ForcesPlaceholder'}}">{{data.militaryForces}}</textarea>
        <button type="button" class="inspire-btn" data-action="inspire" data-field="militaryForces">
          <i class="fas fa-dice-d20"></i>
        </button>
      </div>
    </div>

    {{!-- Fortifications --}}
    <div class="form-group">
      <label>{{localize "LORE_FORGE.Kingdom.Military.Fortifications"}}</label>
      <div class="inspiration-row">
        <textarea name="fortifications" rows="3"
                  placeholder="{{localize 'LORE_FORGE.Kingdom.Military.FortificationsPlaceholder'}}">{{data.fortifications}}</textarea>
        <button type="button" class="inspire-btn" data-action="inspire" data-field="fortifications">
          <i class="fas fa-dice-d20"></i>
        </button>
      </div>
    </div>

    {{!-- Military Traditions --}}
    <div class="form-group">
      <label>{{localize "LORE_FORGE.Kingdom.Military.Traditions"}}</label>
      <div class="inspiration-row">
        <textarea name="militaryTraditions" rows="3"
                  placeholder="{{localize 'LORE_FORGE.Kingdom.Military.TraditionsPlaceholder'}}">{{data.militaryTraditions}}</textarea>
        <button type="button" class="inspire-btn" data-action="inspire" data-field="militaryTraditions">
          <i class="fas fa-dice-d20"></i>
        </button>
      </div>
    </div>

    {{!-- External Threats --}}
    <div class="form-group">
      <label>{{localize "LORE_FORGE.Kingdom.Military.Threats"}}</label>
      <div class="inspiration-row">
        <textarea name="externalThreats" rows="3"
                  placeholder="{{localize 'LORE_FORGE.Kingdom.Military.ThreatsPlaceholder'}}">{{data.externalThreats}}</textarea>
        <button type="button" class="inspire-btn" data-action="inspire" data-field="externalThreats">
          <i class="fas fa-dice-d20"></i>
        </button>
      </div>
    </div>
  </div>
</section>
