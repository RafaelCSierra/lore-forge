<section class="lore-forge-step" data-step="trade">
  <h2>{{localize "LORE_FORGE.Settlement.Steps.Trade"}}</h2>
  <p class="step-description">{{localize "LORE_FORGE.Settlement.Trade.Desc"}}</p>

  <div class="lf-form">
    {{!-- Market --}}
    <div class="form-group">
      <label>{{localize "LORE_FORGE.Settlement.Trade.Market"}}</label>
      <div class="inspiration-row">
        <textarea name="market" rows="2"
                  placeholder="{{localize 'LORE_FORGE.Settlement.Trade.MarketPlaceholder'}}">{{data.market}}</textarea>
        <button type="button" class="inspire-btn" data-action="inspire" data-field="markets">
          <i class="fas fa-dice-d20"></i>
        </button>
      </div>
    </div>

    {{!-- Trade Routes --}}
    <div class="form-group">
      <label>{{localize "LORE_FORGE.Settlement.Trade.TradeRoutes"}}</label>
      <div class="inspiration-row">
        <textarea name="settlTradeRoutes" rows="2"
                  placeholder="{{localize 'LORE_FORGE.Settlement.Trade.TradeRoutesPlaceholder'}}">{{data.settlTradeRoutes}}</textarea>
        <button type="button" class="inspire-btn" data-action="inspire" data-field="tradeRoutes">
          <i class="fas fa-dice-d20"></i>
        </button>
      </div>
    </div>

    {{!-- Notable Buildings --}}
    <div class="form-group">
      <label>{{localize "LORE_FORGE.Settlement.Trade.NotableBuildings"}}</label>
      <div class="inspiration-row">
        <textarea name="notableBuildings" rows="2"
                  placeholder="{{localize 'LORE_FORGE.Settlement.Trade.NotableBuildingsPlaceholder'}}">{{data.notableBuildings}}</textarea>
        <button type="button" class="inspire-btn" data-action="inspire" data-field="notableBuildings">
          <i class="fas fa-dice-d20"></i>
        </button>
      </div>
    </div>

    {{!-- Infrastructure --}}
    <div class="form-group">
      <label>{{localize "LORE_FORGE.Settlement.Trade.Infrastructure"}}</label>
      <div class="inspiration-row">
        <textarea name="infrastructure" rows="2"
                  placeholder="{{localize 'LORE_FORGE.Settlement.Trade.InfrastructurePlaceholder'}}">{{data.infrastructure}}</textarea>
        <button type="button" class="inspire-btn" data-action="inspire" data-field="infrastructure">
          <i class="fas fa-dice-d20"></i>
        </button>
      </div>
    </div>
  </div>
</section>
