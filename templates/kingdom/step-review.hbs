<section class="lore-forge-step" data-step="review">
  <h2>{{localize "LORE_FORGE.Kingdom.Steps.Review"}}</h2>
  <p class="step-description">{{localize "LORE_FORGE.Kingdom.Review.Desc"}}</p>

  <div class="lf-review-preview">
    {{!-- Identity --}}
    <h3><i class="fas fa-crown"></i> {{data.name}}</h3>
    {{#if data.motto}}<p><em>"{{data.motto}}"</em></p>{{/if}}

    <div class="lf-field">
      <span class="lf-field-label">{{localize "LORE_FORGE.Kingdom.Review.Type"}}:</span>
      {{kingdomTypeLabel}}
    </div>

    {{!-- Geography --}}
    <h4><i class="fas fa-mountain"></i> {{localize "LORE_FORGE.Kingdom.Review.Geography"}}</h4>
    <div class="lf-field">
      <span class="lf-field-label">{{localize "LORE_FORGE.Kingdom.Review.Terrain"}}:</span>
      {{terrainLabel}}
    </div>
    <div class="lf-field">
      <span class="lf-field-label">{{localize "LORE_FORGE.Kingdom.Review.Climate"}}:</span>
      {{climateLabel}}
    </div>
    {{#if data.landmarks}}
    <div class="lf-field">
      <span class="lf-field-label">{{localize "LORE_FORGE.Kingdom.Review.Landmarks"}}:</span>
      {{data.landmarks}}
    </div>
    {{/if}}

    {{!-- Government --}}
    <h4><i class="fas fa-landmark"></i> {{localize "LORE_FORGE.Kingdom.Review.Government"}}</h4>
    <div class="lf-field">
      <span class="lf-field-label">{{localize "LORE_FORGE.Kingdom.Review.GovType"}}:</span>
      {{govTypeLabel}}
    </div>
    {{#if data.rulerName}}
    <div class="lf-field">
      <span class="lf-field-label">{{localize "LORE_FORGE.Kingdom.Review.Ruler"}}:</span>
      {{data.rulerName}}{{#if data.rulerDesc}} — {{data.rulerDesc}}{{/if}}
    </div>
    {{/if}}
    {{#if data.culture}}
    <div class="lf-field">
      <span class="lf-field-label">{{localize "LORE_FORGE.Kingdom.Review.Culture"}}:</span>
      {{data.culture}}
    </div>
    {{/if}}

    {{!-- History & Economy --}}
    {{#if hasHistory}}
    <h4><i class="fas fa-book-open"></i> {{localize "LORE_FORGE.Kingdom.Review.History"}}</h4>
    {{#if data.foundingStory}}
    <div class="lf-field">
      <span class="lf-field-label">{{localize "LORE_FORGE.Kingdom.Review.FoundingStory"}}:</span>
      {{data.foundingStory}}
    </div>
    {{/if}}
    <div class="lf-field">
      <span class="lf-field-label">{{localize "LORE_FORGE.Kingdom.Review.WealthLevel"}}:</span>
      {{wealthLevelLabel}}
    </div>
    {{#if data.industries}}
    <div class="lf-field">
      <span class="lf-field-label">{{localize "LORE_FORGE.Kingdom.Review.Industries"}}:</span>
      {{data.industries}}
    </div>
    {{/if}}
    {{/if}}

    {{!-- Conflicts & Faith --}}
    {{#if hasConflicts}}
    <h4><i class="fas fa-shield-halved"></i> {{localize "LORE_FORGE.Kingdom.Review.Conflicts"}}</h4>
    {{#if data.religion}}
    <div class="lf-field">
      <span class="lf-field-label">{{localize "LORE_FORGE.Kingdom.Review.Religion"}}:</span>
      {{data.religion}}
    </div>
    {{/if}}
    {{#if data.faction1Name}}
    <div class="lf-field">
      <span class="lf-field-label">{{data.faction1Name}}:</span>
      {{data.faction1Goals}}
    </div>
    {{/if}}
    {{#if data.externalThreats}}
    <div class="lf-field">
      <span class="lf-field-label">{{localize "LORE_FORGE.Kingdom.Review.ExternalThreats"}}:</span>
      {{data.externalThreats}}
    </div>
    {{/if}}
    {{#if data.internalConflicts}}
    <div class="lf-field">
      <span class="lf-field-label">{{localize "LORE_FORGE.Kingdom.Review.InternalConflicts"}}:</span>
      {{data.internalConflicts}}
    </div>
    {{/if}}
    {{/if}}
  </div>
</section>
